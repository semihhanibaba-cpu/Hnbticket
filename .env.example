# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FIREBASE_PROJECT_ID: The ID of your Firebase Cloud project.
# Automatically read from firebase-applet-config.json, but can be customized here.
FIREBASE_PROJECT_ID=

# FIRESTORE_DATABASE_ID: The ID of the specific Firestore Database to use.
# Automatically read from firebase-applet-config.json, but can be customized here.
FIRESTORE_DATABASE_ID=

# VERCEL KV CONFIGURATION
# Vercel automatically injects these when you connect Vercel KV (Redis) to your project.
# Standard local development falls back to the local db.json file if these are not set.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
